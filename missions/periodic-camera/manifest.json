{
  "schema_version": 1,
  "name": "periodic-camera",
  "version": "0.1.0",
  "entrypoint": "mission.py",
  "permissions": [
    "camera.capture",
    "system.status"
  ],
  "configuration": {
    "hal_base_url": "http://127.0.0.1:3000",
    "capture_interval_seconds": 30,
    "request_timeout_seconds": 10,
    "maximum_captures": 10
  }
}
