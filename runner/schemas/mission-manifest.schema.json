{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sat-runtime.local/schemas/mission-manifest.schema.json",
  "title": "Satellite Mission Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "version",
    "entrypoint",
    "permissions",
    "configuration"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+\\.py$"
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "camera.capture",
          "system.status"
        ]
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_interval_seconds",
        "request_timeout_seconds",
        "maximum_captures"
      ],
      "properties": {
        "hal_base_url": {
          "type": "string",
          "minLength": 1
        },
        "capture_interval_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 86400
        },
        "request_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 300
        },
        "maximum_captures": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
